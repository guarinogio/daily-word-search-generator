{
  "name": "daily-word-search-generator",
  "version": "0.1.0",
  "description": "TypeScript CLI to generate daily word lists and word-search puzzle data for a React app.",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "generate": "tsx src/cli/index.ts generate-words",
    "build:puzzles": "tsx src/cli/index.ts build-puzzles",
    "daily": "tsx src/cli/index.ts daily",
    "check": "tsc --noEmit",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "keywords": [
    "typescript",
    "cli",
    "gemini",
    "word-search",
    "daily-game",
    "react"
  ],
  "author": "giovaguarino",
  "license": "MIT",
  "dependencies": {
    "@blex41/word-search": "^1.0.10",
    "commander": "^14.0.1",
    "dotenv": "^17.2.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.5.2",
    "eslint": "^10.2.0",
    "prettier": "^3.6.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0"
  }
}
