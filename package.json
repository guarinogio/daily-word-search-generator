{
  "name": "daily-word-search-generator",
  "version": "0.1.0",
  "description": "TypeScript CLI to generate daily word lists and word-search puzzle data for a React app.",
  "private": true,
  "type": "module",
  "packageManager": "npm@11",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "generate": "tsx src/cli/index.ts generate-words",
    "build:puzzles": "tsx src/cli/index.ts build-puzzles",
    "daily": "tsx src/cli/index.ts daily",
    "daily:multi": "tsx src/cli/index.ts daily-multi",
    "check": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "validate": "npm run lint && npm run check",
    "build:manual": "tsx src/cli/index.ts build-manual",
    "ci": "npm ci && npm run validate"
  },
  "keywords": [
    "typescript",
    "cli",
    "gemini",
    "word-search",
    "daily-game",
    "react"
  ],
  "author": "giovaguarino",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/guarinogio/daily-word-search-generator.git"
  },
  "bugs": {
    "url": "https://github.com/guarinogio/daily-word-search-generator/issues"
  },
  "homepage": "https://github.com/guarinogio/daily-word-search-generator#readme",
  "dependencies": {
    "@blex41/word-search": "^1.0.10",
    "commander": "^14.0.1",
    "dotenv": "^17.2.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.5.2",
    "eslint": "^10.2.0",
    "prettier": "^3.6.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0"
  }
}
